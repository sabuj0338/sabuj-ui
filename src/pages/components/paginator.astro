---
import * as UIPaginator from "@/components/ui/paginator"
import Layout from "@/layouts/main.astro"
import SiteHeader from "@/components/site-header.astro"
import paginatorCode from "@/components/ui/paginator.tsx?raw"
import {
  Copy,
  Database,
  Download,
  FileCode2,
  FileText,
  PanelLeft,
  Terminal,
} from "lucide-react"

const component = {
  id: "paginator",
  name: "Paginator",
  status: "Ready",
  description:
    "A table-friendly pagination control with page links, first and last actions, page size selection, and quick page jumps.",
  file: "src/components/ui/paginator.tsx",
  source: paginatorCode,
  exports: ["Paginator", "PaginatorProps"],
  dependencies: [
    "lucide-react",
    "@/components/ui/pagination",
    "@/components/ui/select",
    "@/components/ui/button",
    "@/components/ui/input",
  ],
  props: [
    {
      name: "currentPage",
      type: "number",
      defaultValue: "-",
      description: "The currently selected page using a one-based page index.",
    },
    {
      name: "totalPages",
      type: "number",
      defaultValue: "-",
      description:
        "The number of available pages. The component returns null when this is 0 or lower.",
    },
    {
      name: "totalItems",
      type: "number",
      defaultValue: "-",
      description:
        "Enables item range text when used with showItemCount and pageSize.",
    },
    {
      name: "pageSize",
      type: "number",
      defaultValue: "10",
      description:
        "The active number of rows per page used for item counts and selector value.",
    },
    {
      name: "pageSizeOptions",
      type: "number[]",
      defaultValue: "[10, 20, 50, 100]",
      description: "Options rendered in the rows-per-page selector.",
    },
    {
      name: "onPageChange",
      type: "(pageNumber: number) => void",
      defaultValue: "-",
      description:
        "Called when the user selects a page, previous/next, first/last, or a valid go-to value.",
    },
    {
      name: "onPageSizeChange",
      type: "(pageSize: number) => void",
      defaultValue: "-",
      description:
        "Called when the page-size selector changes. Required to show that selector.",
    },
    {
      name: "showPreviousNext",
      type: "boolean",
      defaultValue: "true",
      description: "Shows or hides previous and next pagination actions.",
    },
    {
      name: "showFirstLast",
      type: "boolean",
      defaultValue: "false",
      description: "Adds icon buttons for jumping to the first and last pages.",
    },
    {
      name: "showPageSizeSelector",
      type: "boolean",
      defaultValue: "false",
      description:
        "Shows the rows-per-page select when onPageSizeChange exists.",
    },
    {
      name: "showGoToPage",
      type: "boolean",
      defaultValue: "false",
      description:
        "Shows a numeric input for jumping to a page on enter or blur.",
    },
    {
      name: "showItemCount",
      type: "boolean",
      defaultValue: "false",
      description: "Shows the current item range when totalItems is provided.",
    },
    {
      name: "compact",
      type: "boolean",
      defaultValue: "false",
      description: "Replaces numbered page links with a compact page summary.",
    },
  ],
}

const noop = () => undefined

const paginatorExample = String.raw`import Paginator from "@/components/ui/paginator"

export function UsersPagination() {
  const [page, setPage] = React.useState(3)
  const [pageSize, setPageSize] = React.useState(20)

  return (
    <Paginator
      currentPage={page}
      totalPages={12}
      totalItems={238}
      pageSize={pageSize}
      onPageChange={setPage}
      onPageSizeChange={setPageSize}
      showFirstLast
      showPageSizeSelector
      showGoToPage
      showItemCount
    />
  )
}`
---

<Layout
  title="Paginator Component - Sabuj UI"
  description="A table-friendly pagination control with page links, first and last actions, page size selection, and quick page jumps."
  keywords="paginator component, react pagination, table pagination, shadcn pagination, tailwind pagination, page size selector"
  type="article"
>
  <div class="min-h-screen bg-background text-foreground">
    <SiteHeader active="paginator" />

    <div
      id="components"
      class="mx-auto grid max-w-7xl gap-8 px-5 pt-24 lg:grid-cols-[17rem_minmax(0,1fr)] lg:px-8"
    >
      <aside class="lg:sticky lg:top-20 lg:h-[calc(100vh-6rem)]">
        <nav aria-label="Documentation navigation" class="space-y-8 text-sm">
          <div>
            <div class="mb-3 flex items-center gap-2 font-semibold">
              <PanelLeft className="size-4 text-primary" />
              Components
            </div>
            <div class="flex flex-col gap-1 border-l-2 border-border/50 pl-3">
              <a
                href={`${import.meta.env.BASE_URL}#components`}
                class="rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:text-foreground"
              >
                Overview
              </a>
              <a
                href={`${import.meta.env.BASE_URL}components/timeline/`}
                class="rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:text-foreground"
              >
                Timeline
              </a>
              <a
                href={`${import.meta.env.BASE_URL}components/paginator/`}
                class="rounded-md bg-accent px-2 py-1.5 font-medium text-foreground transition-colors"
              >
                Paginator
              </a>
              <a
                href={`${import.meta.env.BASE_URL}components/phone-input/`}
                class="rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:text-foreground"
              >
                Phone Input
              </a>
              <a
                href={`${import.meta.env.BASE_URL}docs/component-documentation-guide/`}
                class="rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:text-foreground"
              >
                Guide
              </a>
            </div>
          </div>

          <div class="hidden lg:block">
            <p class="mb-3 font-semibold">On this page</p>
            <div class="flex flex-col gap-1 border-l-2 border-border/50 pl-3">
              <a
                href="#preview"
                class="block rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground"
              >
                Preview
              </a>
              <a
                href="#usage"
                class="block rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground"
              >
                Usage
              </a>
              <a
                href="#api"
                class="block rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground"
              >
                API reference
              </a>
            </div>
          </div>
        </nav>
      </aside>

      <main class="min-w-0">
        <section class="mb-8 space-y-4">
          <div class="flex flex-wrap items-center gap-2">
            <span
              class="inline-flex items-center rounded-md bg-primary/10 px-2 py-1 text-xs font-medium text-primary ring-1 ring-primary/20"
            >
              {component.status}
            </span>
            <code
              class="rounded-md bg-muted px-2 py-1 text-xs text-muted-foreground"
            >
              {component.file}
            </code>
          </div>
          <div class="space-y-3">
            <p class="text-sm font-medium text-primary">Component</p>
            <h1 class="text-4xl font-bold tracking-tight">{component.name}</h1>
            <p class="max-w-2xl text-base leading-7 text-muted-foreground">
              {component.description}
            </p>
          </div>
        </section>

        <section class="rounded-lg border bg-background shadow-sm">
          <div class="min-w-0 divide-y">
            <section id="preview" class="scroll-mt-24 p-5 md:p-6">
              <div
                class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
              >
                <div
                  class="inline-flex w-fit items-center rounded-md border bg-muted p-1 text-sm font-medium"
                  role="tablist"
                >
                  <button
                    type="button"
                    class="rounded-sm bg-background px-3 py-1.5 shadow-sm transition-all focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
                    role="tab"
                    aria-selected="true"
                    data-tab-group="paginator"
                    data-tab-target="paginator-preview-content"
                  >
                    Preview
                  </button>
                  <button
                    type="button"
                    class="rounded-sm px-3 py-1.5 text-muted-foreground transition-all hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
                    role="tab"
                    aria-selected="false"
                    data-tab-group="paginator"
                    data-tab-target="paginator-code-content"
                  >
                    Code
                  </button>
                </div>

                <div class="flex items-center gap-2">
                  <button
                    type="button"
                    class="inline-flex h-8 items-center justify-center gap-2 rounded-md border bg-background px-3 text-xs font-medium transition-colors hover:bg-accent"
                    data-copy-target="paginator-source"
                  >
                    <Copy className="size-3.5" />
                    <span data-button-label>Copy</span>
                  </button>
                  <button
                    type="button"
                    class="inline-flex h-8 items-center justify-center gap-2 rounded-md border bg-background px-3 text-xs font-medium transition-colors hover:bg-accent"
                    data-download-target="paginator-source"
                    data-download-file="paginator.tsx"
                  >
                    <Download className="size-3.5" />
                    <span data-button-label>Download</span>
                  </button>
                </div>
              </div>

              <div id="paginator-preview-content" role="tabpanel">
                <div class="overflow-hidden rounded-lg border bg-muted/20">
                  <div class="space-y-6 bg-background/86 p-5 md:p-8">
                    <div class="rounded-lg border bg-background">
                      <div
                        class="grid grid-cols-[1.4fr_0.8fr_0.8fr] gap-4 border-b px-4 py-3 text-xs font-medium text-muted-foreground"
                      >
                        <span>Customer</span>
                        <span>Status</span>
                        <span class="text-right">Total</span>
                      </div>
                      {
                        ["Acme Co.", "Northstar Labs", "GreenField"].map(
                          (name, index) => (
                            <div class="grid grid-cols-[1.4fr_0.8fr_0.8fr] gap-4 border-b px-4 py-3 text-sm last:border-b-0">
                              <span class="font-medium">{name}</span>
                              <span class="text-muted-foreground">
                                {index === 1 ? "Review" : "Active"}
                              </span>
                              <span class="text-right font-medium">
                                ${["4,280", "1,940", "7,125"][index]}
                              </span>
                            </div>
                          )
                        )
                      }
                    </div>

                    <UIPaginator.default
                      currentPage={3}
                      totalPages={12}
                      totalItems={238}
                      pageSize={20}
                      onPageChange={noop}
                      onPageSizeChange={noop}
                      showFirstLast
                      showPageSizeSelector
                      showGoToPage
                      showItemCount
                    />

                    <div class="border-t pt-6">
                      <UIPaginator.default
                        currentPage={8}
                        totalPages={24}
                        onPageChange={noop}
                        showFirstLast
                        compact
                      />
                    </div>
                  </div>
                </div>
              </div>

              <div id="paginator-code-content" role="tabpanel" class="hidden">
                <pre
                  class="max-h-152 overflow-auto rounded-lg border bg-zinc-950 p-4 text-sm leading-6 text-zinc-100"><code id="paginator-source">{component.source}</code></pre>
              </div>

              <div class="mt-6 rounded-lg border bg-muted/20 p-5 md:p-6">
                <div class="grid gap-6 sm:grid-cols-3">
                  <div>
                    <h3 class="mb-3 text-sm font-semibold">Exports</h3>
                    <div class="flex flex-wrap gap-2">
                      {
                        component.exports.map((item) => (
                          <code class="rounded-md border bg-background px-2 py-1 text-xs">
                            {item}
                          </code>
                        ))
                      }
                    </div>
                  </div>
                  <div>
                    <h3 class="mb-3 text-sm font-semibold">Dependencies</h3>
                    <div class="flex flex-wrap gap-2">
                      {
                        component.dependencies.map((item) => (
                          <div class="rounded-md border bg-background px-2 py-1 text-xs">
                            <code>{item}</code>
                          </div>
                        ))
                      }
                    </div>
                  </div>
                  <div>
                    <h3 class="mb-3 text-sm font-semibold">Install notes</h3>
                    <p class="text-xs leading-5 text-muted-foreground">
                      Built from the local pagination, select, button, and input
                      primitives. Keep <code>pageSize</code>, <code
                        >totalItems</code
                      >, and external table state in sync.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <section id="usage" class="scroll-mt-24 p-5 md:p-6">
              <div class="mb-4 flex items-center gap-2 text-sm font-semibold">
                <Terminal className="size-4 text-primary" />
                Usage
              </div>
              <pre
                class="overflow-auto rounded-lg border bg-muted p-4 text-sm leading-6"><code>{paginatorExample}</code></pre>
            </section>

            <section id="api" class="scroll-mt-24 p-5 md:p-6">
              <div class="mb-4 flex items-center gap-2 text-sm font-semibold">
                <FileCode2 className="size-4 text-primary" />
                API reference
              </div>
              <div class="overflow-x-auto rounded-lg border">
                <table class="w-full min-w-2xl text-left text-sm">
                  <thead
                    class="border-b bg-muted/60 text-xs text-muted-foreground"
                  >
                    <tr>
                      <th class="px-4 py-3 font-medium">Prop</th>
                      <th class="px-4 py-3 font-medium">Type</th>
                      <th class="px-4 py-3 font-medium">Default</th>
                      <th class="px-4 py-3 font-medium">Description</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y">
                    {
                      component.props.map((prop) => (
                        <tr>
                          <td class="px-4 py-3 align-top">
                            <code class="font-semibold">{prop.name}</code>
                          </td>
                          <td class="px-4 py-3 align-top text-muted-foreground">
                            <code>{prop.type}</code>
                          </td>
                          <td class="px-4 py-3 align-top text-muted-foreground">
                            <code>{prop.defaultValue}</code>
                          </td>
                          <td class="px-4 py-3 align-top leading-6">
                            {prop.description}
                          </td>
                        </tr>
                      ))
                    }
                  </tbody>
                </table>
              </div>
            </section>

            <section class="border-t px-6 py-10">
              <div
                class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start"
              >
                <div class="space-y-4">
                  <p class="text-sm font-medium text-primary">Pattern</p>
                  <h2 class="text-3xl font-semibold">
                    Connect it to table state
                  </h2>
                  <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
                    Paginator is controlled. Store page and page size in the
                    parent component, then fetch or slice data from that state.
                  </p>
                  <a
                    href={`${import.meta.env.BASE_URL}docs/component-documentation-guide/`}
                    class="inline-flex h-10 items-center justify-center gap-2 rounded-md border bg-background px-4 text-sm font-medium transition-colors hover:bg-accent"
                  >
                    <FileText className="size-4" />
                    Open guide file
                  </a>
                </div>

                <div class="rounded-lg border bg-background p-4 shadow-sm">
                  <div
                    class="mb-3 flex items-center gap-2 text-sm font-semibold"
                  >
                    <Database className="size-4 text-primary" />
                    Data views
                  </div>
                  <p class="text-sm leading-6 text-muted-foreground">
                    Best for tables, search results, audit logs, and admin lists
                    with server-driven pagination.
                  </p>
                </div>
              </div>
            </section>
          </div>
        </section>
      </main>
    </div>
  </div>

  <script>
    const copyButtons = document.querySelectorAll("[data-copy-target]")
    const downloadButtons = document.querySelectorAll("[data-download-target]")
    const tabButtons = document.querySelectorAll("[data-tab-target]")

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const targetId = button.getAttribute("data-copy-target")
        const target = targetId ? document.getElementById(targetId) : null
        const code = target?.textContent ?? ""
        const label = button.querySelector("[data-button-label]")
        const originalText = label?.textContent ?? "Copy"

        await navigator.clipboard.writeText(code)
        if (label) label.textContent = "Copied"

        window.setTimeout(() => {
          if (label) label.textContent = originalText
        }, 1400)
      })
    })

    downloadButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const targetId = button.getAttribute("data-download-target")
        const fileName =
          button.getAttribute("data-download-file") ?? "component.tsx"
        const target = targetId ? document.getElementById(targetId) : null
        const code = target?.textContent ?? ""
        const blob = new Blob([code], { type: "text/plain;charset=utf-8" })
        const url = URL.createObjectURL(blob)
        const link = document.createElement("a")

        link.href = url
        link.download = fileName
        link.click()
        URL.revokeObjectURL(url)
      })
    })

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const group = button.getAttribute("data-tab-group")
        const targetId = button.getAttribute("data-tab-target")

        document
          .querySelectorAll(`[data-tab-group="${group}"]`)
          .forEach((btn) => {
            btn.setAttribute("aria-selected", "false")
            btn.classList.remove(
              "bg-background",
              "shadow-sm",
              "text-foreground"
            )
            btn.classList.add("text-muted-foreground")
          })

        button.setAttribute("aria-selected", "true")
        button.classList.add("bg-background", "shadow-sm", "text-foreground")
        button.classList.remove("text-muted-foreground")

        const section = button.closest("section")
        if (section) {
          section.querySelectorAll('[role="tabpanel"]').forEach((panel) => {
            panel.classList.add("hidden")
          })
          const targetPanel = document.getElementById(targetId || "")
          if (targetPanel) {
            targetPanel.classList.remove("hidden")
          }
        }
      })
    })
  </script>
</Layout>
