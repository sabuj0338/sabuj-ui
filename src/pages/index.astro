---
import {
  Timeline,
  TimelineIndicator,
  TimelineItem,
  TimelineSeparator,
  TimelineTitle,
} from "@/components/ui/timeline"
import Layout from "@/layouts/main.astro"
import timelineCode from "@/components/ui/timeline.tsx?raw"
import {
  BookOpen,
  Check,
  Code2,
  Copy,
  Download,
  Eye,
  FileCode2,
  FileText,
  Layers3,
  Package,
  PanelLeft,
  Sparkles,
  Terminal,
  Moon,
  Sun,
} from "lucide-react"

const components = [
  {
    id: "timeline",
    name: "Timeline",
    status: "Ready",
    description:
      "A composable timeline primitive for order progress, onboarding flows, release steps, and status-driven UI.",
    file: "src/components/ui/timeline.tsx",
    source: timelineCode,
    exports: [
      "Timeline",
      "TimelineItem",
      "TimelineIndicator",
      "TimelineSeparator",
      "TimelineTitle",
    ],
    dependencies: ["class-variance-authority", "lucide-react", "@/lib/utils"],
    props: [
      {
        name: "orientation",
        type: '"horizontal" | "vertical"',
        defaultValue: '"horizontal"',
        description: "Changes the layout direction for the entire timeline.",
      },
      {
        name: "status",
        type: '"default" | "completed" | "current"',
        defaultValue: '"default"',
        description:
          "Controls indicator, title, and separator styling for each timeline state.",
      },
      {
        name: "className",
        type: "string",
        defaultValue: "-",
        description:
          "Extends the generated Tailwind classes through the local cn utility.",
      },
    ],
  },
]

const timelineExample = String.raw`import {
  Timeline,
  TimelineIndicator,
  TimelineItem,
  TimelineSeparator,
  TimelineTitle,
} from "@/components/ui/timeline"
import { Check } from "lucide-react"

export function OrderTimeline() {
  return (
    <Timeline orientation="horizontal">
      <TimelineItem>
        <TimelineIndicator status="completed">
          <Check />
        </TimelineIndicator>
        <TimelineTitle status="completed">Order Placed</TimelineTitle>
      </TimelineItem>
      <TimelineSeparator status="completed" />
      <TimelineItem>
        <TimelineIndicator status="current">
          <Check />
        </TimelineIndicator>
        <TimelineTitle status="current">Shipped</TimelineTitle>
      </TimelineItem>
    </Timeline>
  )
}`
