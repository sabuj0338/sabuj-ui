---
import SiteHeader from "@/components/site-header.astro"
import Layout from "@/layouts/main.astro"
import {
  ArrowRight,
  FileCode2,
  FileText,
  Layers3,
  Package,
  Sparkles,
} from "lucide-react"

const components = [
  {
    id: "timeline",
    name: "Timeline",
    status: "Ready",
    href: "/components/timeline/",
    description:
      "A composable timeline primitive for order progress, onboarding flows, release steps, and status-driven UI.",
    exports: 5,
  },
  {
    id: "paginator",
    name: "Paginator",
    status: "Ready",
    href: "/components/paginator/",
    description:
      "A table-friendly pagination control with page links, first and last actions, page size selection, and quick page jumps.",
    exports: 1,
  },
  {
    id: "phone-input",
    name: "Phone Input",
    status: "Ready",
    href: "/components/phone-input/",
    description:
      "An international phone number input with country search, dialing codes, flags, and shadcn-styled controls.",
    exports: 1,
  },
]
---

<Layout
  title="Sabuj UI - Component Library"
  description="A documentation landing page for custom React components built with Astro, Tailwind CSS, and shadcn/ui patterns."
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader active="components" />

    <main class="flex-1">
      <section class="relative overflow-hidden border-b">
        {/* Glow Effects */}
        <div class="pointer-events-none absolute inset-0 overflow-hidden">
          <div
            class="absolute top-[-20%] left-[-10%] h-[500px] w-[500px] rounded-full bg-primary/30 blur-[120px]"
          >
          </div>
          <div
            class="absolute top-[20%] right-[-10%] h-[400px] w-[400px] rounded-full bg-blue-500/30 blur-[100px]"
          >
          </div>
          <div
            class="absolute bottom-[-20%] left-[20%] h-[600px] w-[600px] rounded-full bg-purple-500/30 blur-[120px]"
          >
          </div>
        </div>

        <div
          class="bg-dot-pattern pointer-events-none absolute inset-0 top-0 opacity-50 mix-blend-overlay"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-0 bg-linear-to-b from-background/5 via-background/50 to-background"
        >
        </div>

        <div
          class="relative mx-auto grid max-w-7xl gap-8 px-5 py-16 lg:grid-cols-[1fr_22rem] lg:px-8 lg:py-24"
        >
          <div class="max-w-3xl space-y-8">
            <div
              class="inline-flex items-center gap-2 rounded-full border border-border/40 bg-background/50 px-3 py-1.5 text-sm font-medium text-muted-foreground shadow-sm backdrop-blur-md"
            >
              <span class="flex size-2 rounded-full bg-primary"></span>
              <Package className="size-4 text-primary" />
              Astro + React + Tailwind CSS
            </div>
            <div class="space-y-4">
              <h1
                class="text-4xl font-extrabold tracking-tight text-balance md:text-6xl lg:text-7xl"
              >
                Beautifully crafted React <span
                  class="bg-linear-to-r from-violet-600 via-indigo-600 to-cyan-500 bg-clip-text text-transparent dark:from-violet-400 dark:via-indigo-400 dark:to-cyan-400"
                  >custom UI</span
                > components
              </h1>
              <p
                class="max-w-2xl text-lg leading-8 font-light text-muted-foreground/80 md:text-xl"
              >
                Discover a collection of highly customizable, accessible, and
                ready-to-use React components. Built with Tailwind CSS and
                shadcn/ui patterns to elevate your web applications.
              </p>
            </div>
            <div class="flex flex-wrap gap-4 pt-2">
              <a
                href="#components"
                class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-primary px-6 text-sm font-medium text-primary-foreground shadow-lg shadow-primary/40 transition-all hover:scale-105 hover:bg-primary/90 hover:shadow-primary/60 active:scale-95"
              >
                <Layers3 className="size-4" />
                Browse components
              </a>
              <a
                href="/docs/component-documentation-guide/"
                class="inline-flex h-11 items-center justify-center gap-2 rounded-full border bg-background/50 px-6 text-sm font-medium shadow-sm backdrop-blur-sm transition-all hover:scale-105 hover:bg-accent hover:text-accent-foreground active:scale-95"
              >
                <FileText className="size-4" />
                Documentation workflow
              </a>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
            <div
              class="group relative overflow-hidden rounded-2xl border bg-background/40 p-6 shadow-sm backdrop-blur-xl transition-all hover:-translate-y-1 hover:bg-background/60 hover:shadow-md"
            >
              <div
                class="absolute inset-0 bg-linear-to-br from-primary/10 to-transparent opacity-0 transition-opacity group-hover:opacity-100"
              >
              </div>
              <div class="relative">
                <div
                  class="mb-4 flex items-center gap-3 text-sm font-medium text-muted-foreground"
                >
                  <div
                    class="rounded-lg bg-primary/10 p-2 ring-1 ring-primary/20"
                  >
                    <Layers3 className="size-4 text-primary" />
                  </div>
                  Library
                </div>
                <p class="text-4xl font-bold tracking-tight text-foreground">
                  {components.length}
                </p>
                <p class="mt-2 text-sm font-medium text-muted-foreground">
                  documented component
                </p>
              </div>
            </div>
            <div
              class="group relative overflow-hidden rounded-2xl border bg-background/40 p-6 shadow-sm backdrop-blur-xl transition-all hover:-translate-y-1 hover:bg-background/60 hover:shadow-md"
            >
              <div
                class="absolute inset-0 bg-linear-to-br from-blue-500/10 to-transparent opacity-0 transition-opacity group-hover:opacity-100"
              >
              </div>
              <div class="relative">
                <div
                  class="mb-4 flex items-center gap-3 text-sm font-medium text-muted-foreground"
                >
                  <div
                    class="rounded-lg bg-blue-500/10 p-2 ring-1 ring-blue-500/20"
                  >
                    <Sparkles className="size-4 text-blue-500" />
                  </div>
                  Pattern
                </div>
                <p class="text-2xl font-bold tracking-tight text-foreground">
                  One page each
                </p>
                <p class="mt-2 text-sm font-medium text-muted-foreground">
                  easier to scale as components grow
                </p>
              </div>
            </div>
            <div
              class="group relative overflow-hidden rounded-2xl border bg-background/40 p-6 shadow-sm backdrop-blur-xl transition-all hover:-translate-y-1 hover:bg-background/60 hover:shadow-md"
            >
              <div
                class="absolute inset-0 bg-linear-to-br from-purple-500/10 to-transparent opacity-0 transition-opacity group-hover:opacity-100"
              >
              </div>
              <div class="relative">
                <div
                  class="mb-4 flex items-center gap-3 text-sm font-medium text-muted-foreground"
                >
                  <div
                    class="rounded-lg bg-purple-500/10 p-2 ring-1 ring-purple-500/20"
                  >
                    <FileCode2 className="size-4 text-purple-500" />
                  </div>
                  Docs
                </div>
                <p class="text-2xl font-bold tracking-tight text-foreground">
                  Preview + API
                </p>
                <p class="mt-2 text-sm font-medium text-muted-foreground">
                  consistent structure per component
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="components" class="mx-auto max-w-7xl px-5 py-14 lg:px-8">
        <div class="mb-8 max-w-2xl space-y-3">
          <p class="text-sm font-medium text-primary">Components</p>
          <h2 class="text-3xl font-semibold">Library overview</h2>
          <p class="text-sm leading-6 text-muted-foreground">
            This page stays lightweight. Use it to scan available components and
            jump into each dedicated documentation page.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {
            components.map((component) => (
              <a
                href={component.href}
                class="group rounded-xl border bg-background p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md"
              >
                <div class="mb-5 flex items-start justify-between gap-4">
                  <div class="rounded-lg bg-primary/10 p-2 text-primary">
                    <Layers3 className="size-5" />
                  </div>
                  <span class="inline-flex items-center rounded-md bg-primary/10 px-2 py-1 text-xs font-medium text-primary ring-1 ring-primary/20">
                    {component.status}
                  </span>
                </div>
                <div class="space-y-2">
                  <h3 class="text-xl font-semibold">{component.name}</h3>
                  <p class="text-sm leading-6 text-muted-foreground">
                    {component.description}
                  </p>
                </div>
                <div class="mt-6 flex items-center justify-between border-t pt-4">
                  <span class="text-xs text-muted-foreground">
                    {component.exports} exports
                  </span>
                  <span class="inline-flex items-center gap-2 text-sm font-medium text-primary">
                    View docs
                    <ArrowRight className="size-4 transition-transform group-hover:translate-x-0.5" />
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>
  </div>
</Layout>
